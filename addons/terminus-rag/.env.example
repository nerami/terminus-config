# Local dev env for ./dev.sh. Copy to .env (gitignored) and fill in.
# Grouped: required HA connection, optional add-on options, dev-only overrides.

# ── Home Assistant connection (required) ─────────────────────────────────────
# The add-on connects to a real Home Assistant to build the index. Use a
# long-lived access token from your HA profile.
HASS_URL=https://homeassistant.local:8123
HASS_TOKEN=

# ── Local dev overrides (dev-only; no effect on-device) ──────────────────────
# Backend bind port for ./dev.sh (default 9000, the add-on contract). Override
# when something else holds 9000 locally — e.g. a langfuse-clickhouse stack also
# uses 9000. The Vite proxy follows this automatically.
# DEV_BACKEND_PORT=9001

# ── Add-on options (optional; mirror config.yaml options on-device) ──────────
# Require a bearer token on /mcp (and ingress-guard the playground). Leave blank
# for fully-open local dev.
# RAG_API_TOKEN=

# Writable data dir (model cache + persisted index). On-device the Supervisor
# mounts /data (the default); set this for laptop dev since /data is the
# read-only macOS root. Point it at a local gitignored dir.
# RAG_DATA_DIR=./addons/terminus-rag/.dev-data
