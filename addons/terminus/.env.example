# Local dev secrets for ./dev.sh. Copy to .env (gitignored) and fill in.
# The agent's Anthropic key — required for chat to work.
ANTHROPIC_API_KEY=

# Point the backend at a real Home Assistant for /ha/status + HA tools.
# Use a long-lived access token from your HA profile.
HASS_URL=https://homeassistant.local:8123
HASS_TOKEN=

# Optional overrides (defaults shown).
# TLC_MODEL=claude-sonnet-4-6
# AUTO_RUN_TOOLS=false

# Optional Langfuse tracing (default OFF). Spin up the stack first:
#   cd observability/langfuse && docker compose up -d
# Then open the UI (http://localhost:63742), create a project, and copy its
# pk-lf-.../sk-lf-... keys below.
# NOTE: LANGFUSE_BASE_URL must be a literal private IP — the should_trace gate
# (app/tracing.py) is fail-closed and refuses "localhost" (a hostname). Use
# 127.0.0.1 for a laptop-local backend; the on-device add-on uses the laptop LAN IP.
# LANGFUSE_TRACING=true
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=http://127.0.0.1:63742
